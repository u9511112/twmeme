{
  "manifest_version": 3,
  "name": "TWmeme",
  "version": "0.0.1",
  "description": "在 LINE / Threads / IG 輸入框打 :meme 直接插入台灣迷因。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://line.me/*",
        "*://*.line.me/*",
        "*://www.threads.com/*",
        "*://*.threads.com/*",
        "*://www.threads.net/*",
        "*://*.threads.net/*",
        "*://www.instagram.com/*",
        "*://*.instagram.com/*"
      ],
      "js": ["db.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://ep-dawn-voice-ao8hd53u-pooler.c-2.ap-southeast-1.aws.neon.tech/*"
  ],
  "permissions": []
}
