# Copy to .env and fill in values
# Never commit .env to git

# Neon Postgres — use the `scraper` role connection string (DML on memes,
# read-only on logs). Get from ~/.gstack/projects/u9511112-twmeme/secrets/neon.env
# Format: postgresql://scraper:<password>@ep-xxx.<region>.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_URL=postgresql://scraper:YOUR_PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=twmeme-memes
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
